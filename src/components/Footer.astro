---
import { SITE_TITLE, SOCIALS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="muted">© {year} {SITE_TITLE}</span>
    <nav class="socials">
      {
        SOCIALS.map((s) => (
          <a href={s.href} target="_blank" rel="me noopener">
            {s.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 2rem 0;
    font-size: 0.9rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .socials {
    display: flex;
    gap: 1rem;
  }
  .socials a {
    color: var(--text-muted);
  }
  .socials a:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
